# posera web 환경변수 예시 — 실제 값은 .env.local 에 넣고 커밋하지 말 것.

# 클라이언트(브라우저) 노출 — Supabase publishable(anon) 키. RLS로 보호.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# 서버 전용 (Next API Route에서만). NEXT_PUBLIC_ 접두어 절대 금지.
SUPABASE_SECRET_KEY=
GEMINI_API_KEY=
