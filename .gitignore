# 환경변수 — API 키 (절대 커밋 금지)
.env

# MCP 설정 — Supabase 액세스 토큰 포함(절대 커밋 금지). 템플릿은 .mcp.json.example
.mcp.json

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/

# 데이터·모델 (대용량 — 준비 스크립트로 재현)
data/mura/
# COCO person-keypoints 다운로드(zip 241MB + json) — 재현 가능, 커밋 금지
data/pose/
*.pt
*.pth
*.onnx

# data/ 학습 산출물 전반(대용량·재현 가능) — *.json/*.log 포함.
# GitHub 100MB 제한 회피(person_keypoints_train2017.json 239MB 등). 벤치마크 입력만 예외.
data/**/*.json
data/**/*.log
!data/benchmark_cases.json

# DB·캐시 (재현 가능 — spec §3)
data/medgate.db
data/cache/

# 아레나 런타임 산출물 (재현 가능)
data/arena_leaderboard.json
data/arena_adopted.json

# 산출물
outputs/
*.log

# MURA 실데이터 (3.3GB — 절대 커밋 금지, 사람이 다운로드)
MURA-v1.1_files/
MURA-v1.1/
data/mura_leaderboard.json

# 진화 산출(재현 가능)
data/evolve_models/
data/evolve_*.json
data/mura_models_gpu/
