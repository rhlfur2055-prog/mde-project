# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# 라이선스 운동 GIF(Gym Visual 등) — 재배포 금지, 커밋 제외
public/exercises/*.gif

# 3D 모델(데모/대용량) — 재다운로드 가능, 커밋 제외
public/models/*.glb

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
public/exercises/*.mp4
public/exercises/**/*.mp4
public/exercises/**/*.gif
